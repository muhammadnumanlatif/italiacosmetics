# ----------------------------------------------------------------------
# 1. Force HTTPS and Non-WWW
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force non-www (optional but good for SEO)
  RewriteCond %{HTTP_HOST} ^www\.italiacosmetics\.com [NC]
  RewriteRule ^(.*)$ https://italiacosmetics.com/$1 [L,R=301]
</IfModule>

# ----------------------------------------------------------------------
# 2. Single Page Application (SPA) Routing Fallback
# ----------------------------------------------------------------------
# This ensures that if you ever switch from hash-based routing (/#shop) 
# to clean URLs (/shop), the server will still load index.html.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# ----------------------------------------------------------------------
# 3. Enable Gzip / Deflate Compression
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript application/json image/svg+xml
</IfModule>

# ----------------------------------------------------------------------
# 4. Browser Caching
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  
  # CSS, JavaScript
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  
  # Others
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Default
  ExpiresDefault "access plus 2 days"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|xml|gz|html)$">
    Header append Vary: Accept-Encoding
  </FilesMatch>
  
  # Prevent caching of sw.js to ensure updates to the Service Worker propagate immediately
  <Files "sw.js">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  </Files>
</IfModule>

# ----------------------------------------------------------------------
# 5. Basic Security Headers
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
